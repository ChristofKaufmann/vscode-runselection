{
  "name": "nb-run-selection",
  "displayName": "Notebook: Run Selection",
  "description": "Execute selected code directly in a notebook cell, like \"Jupyter: Run Selection/Line in Interactive Window\" but for notebooks.",
  "author": "Christof Kaufmann",
  "publisher": "ChristofKaufmann",
  "version": "0.0.5-dev",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "icon/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChristofKaufmann/vscode-runselection"
  },
  "categories": ["Notebooks"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "extensionDependencies": ["ms-toolsai.jupyter"],
  "contributes": {
    "commands": [
      {
        "command": "nb-run-selection.runSelectionOrLine",
        "title": "Notebook: Run Selection/Line"
      }
    ],
    "keybindings": [
      {
        "command": "nb-run-selection.runSelectionOrLine",
        "key": "shift+enter",
        "when": "editorHasSelection && notebookCellEditorFocused && !interactiveEditorFocused"
      }
    ],
    "configuration": {
      "title": "Notebook Run Selection",
      "properties": {
        "nbRunSelection.showExceptionsAsNotification": {
          "type": "boolean",
          "default": false,
          "description": "Show kernel exceptions as a notification popup. Disable to render them as cell output instead."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && tsc -p tsconfig.test.json && vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "24.x",
    "@types/mocha": "^10.0.6",
    "@vscode/test-cli": "0.x",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.4.0"
  }
}
